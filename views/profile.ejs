<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="w-full h-screen text-white bg-zinc-800 p-10">
        <div class="w-full flex justify-end">
            <a class="bg-red-500 rounded-md px-3 py-2 text-sm inline-block mb-5" href="/">Log Out</a>
        </div>

        <h3 class="text-3xl mb-3"><samp class="">Hello,</samp>
            <%= user.username %>
        </h3>
        <h5 class="mb-5">You can create a post</h5>
        <form method="post" action="/post">
            <textarea placeholder="what's on your mind"
                class="p-3 outline-none block  w-1/3 resize-none bg-transparent border-2 border-zinc-700 rounded-md"
                name="content" id=""></textarea>
            <input class="text-white px-3 w-40 rounded-md mt-2 block py-2 bg-blue-500" value="Create new post"
                type="submit">
        </form>
        <div class="posts mt-20">
            <h3 class="text-3xl text-zinc-400">Your posts.</h3>
            <div class="postcontainer mt-5">
                <%user.posts.reverse().forEach(function(post){ %>
                    <div class="post w-1/3 p-4 rounded-md mb-4 border-2 border-zinc-700 bg-zinc-700">
                        <h4 class="text-blue-500 mb-2"><%=user.username%></h4>
                        <p class="text-sm tracking-tighter"><%= post.content%></p>
                        <small class="mt-1 inline-block"><%=post.likes.length%> likes</small>
                        <div class="btns flex gap-4 mt-5">
                            <a class="text-blue-500" href="/like/<%=post._id%>">
                                <%= post.likes.indexOf(user._id)=== -1 ? "Like":"Unlike" %>
                                </a>
                            <a class="text-zinc-600" href="/edit/<%= post._id%>">Edit</a>
                        </div>
                    </div>

                <%})%>
            </div>

        </div>
    </div>
</body>

</html>