<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="w-full h-screen text-white bg-zinc-800 p-10">
        <div class="w-full flex justify-end">
            <a class="bg-red-500 rounded-md px-3 py-2 text-sm inline-block mb-5" href="/">Log Out</a>
        </div>
        <h5 class="mb-5">Edit your post</h5>
        <form method="post" action="/update/<%=post._id%>">
            <textarea placeholder="what's on your mind"
                class="p-3 outline-none block  w-1/3 resize-none bg-transparent border-2 border-zinc-700 rounded-md"
                name="content" id=""><%= post.content%></textarea>
            <input class="text-black px-3 w-40 rounded-md mt-2 block py-2 bg-yellow-600" value="Update post"
                type="submit">
        </form>
        
    </div>
</body>

</html>