<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-screen text-white bg-zinc-800 p-10">
        <h3 class="text-3xl mb-3" >Create user</h3>
        <a class="text-xl  mb-3 flex justify-end bg-zinc-800 inline-block " href="/login">Login</a>
        <form action="/register" method="post">
        <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-700"  type="text" placeholder="name" name="name">
        <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-700"  type="text" placeholder="Username" name="username">
        <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-700"  type="text" placeholder="Email" name="email">
        <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-700"  type="text" placeholder="Password" name="password">
        <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-700"  type="text" placeholder="Age" name="age">
        <input class="px-4 py-2 rounded-md bg-blue-500"  type="submit" value="create user">
    </form> 
    </div>
    
</body>
</html>